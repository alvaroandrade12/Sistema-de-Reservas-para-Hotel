# ==========================================================
# .env.example - Plantilla de variables de entorno
# Instrucciones: Copia este archivo como '.env' y pon tus datos reales.
# ==========================================================

# --- PostgreSQL (Base de datos) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=tu_contraseña_aqui
POSTGRES_DB=gestion_academica
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# --- Backend (NestJS) ---
# La URL de conexión suele armarse así: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:tu_contraseña_aqui@localhost:5432/gestion_academica?schema=public"
PORT=3001
NODE_ENV=development

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1    